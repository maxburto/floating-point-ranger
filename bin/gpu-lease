#!/opt/gpu-manager/venv/bin/python
"""gpu-lease — run a command under a gpu-manager lease (successor of the old flock CLI).

    gpu-lease [--gpu batch|interactive|<UUID>] [--vram MIB] [--label NAME]
              [--timeout SEC] [--shared] -- <command> [args...]

Requests admission from the gpu-manager service, pins the command to the granted card via
CUDA_VISIBLE_DEVICES, heartbeats while it runs, releases on exit (any exit path). Deferrals
poll honestly until --timeout (default: wait forever). Token comes from /opt/gpu-manager/env
or $GPU_MANAGER_TOKEN. Never preempts anything — if the GPU is busy, you wait.
"""
from __future__ import annotations

import argparse
import json
import os
import signal
import subprocess
import sys
import threading
import time
import urllib.error
import urllib.request

URL = os.environ.get("GPU_MANAGER_URL", "http://127.0.0.1:8768").rstrip("/")


def _token() -> str:
    tok = os.environ.get("GPU_MANAGER_TOKEN", "")
    if not tok and os.path.exists("/opt/gpu-manager/env"):
        try:
            for line in open("/opt/gpu-manager/env"):
                if line.startswith("GPU_MANAGER_TOKEN="):
                    tok = line.split("=", 1)[1].strip()
        except PermissionError:
            pass
    if not tok:
        sys.exit("gpu-lease: no token (need root for /opt/gpu-manager/env, or set GPU_MANAGER_TOKEN)")
    return tok


def _call(method: str, path: str, body: dict | None, tok: str) -> tuple[int, dict]:
    req = urllib.request.Request(
        f"{URL}{path}", method=method,
        data=json.dumps(body).encode() if body is not None else None,
        headers={"Authorization": f"Bearer {tok}", "Content-Type": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=15) as r:
            return r.status, json.loads(r.read() or b"{}")
    except urllib.error.HTTPError as e:
        return e.code, json.loads(e.read() or b"{}")


def _start_vouch_responder() -> int | None:
    """Trivial always-alive health endpoint for the stall-watch health-ping contract: while this
    wrapped job runs, its owner (us) vouches it is alive. Localhost-only — the gpu-manager runs on
    the same host and GETs this URL when a lease looks idle. Returns the bound port (or None)."""
    import http.server

    class _H(http.server.BaseHTTPRequestHandler):
        def do_GET(self):  # noqa: N802
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(b'{"alive": true}')

        def log_message(self, *a):  # keep the wrapped job's stderr clean
            pass

    try:
        srv = http.server.HTTPServer(("127.0.0.1", 0), _H)
    except OSError as e:
        print(f"gpu-lease: WARNING — could not start the vouch responder ({e}); this job runs "
              "with no health_url and could be flagged/reaped if it goes idle", file=sys.stderr)
        return None
    threading.Thread(target=srv.serve_forever, daemon=True).start()
    return srv.server_address[1]


def main() -> int:
    ap = argparse.ArgumentParser(add_help=True)
    ap.add_argument("--gpu", default="batch")
    ap.add_argument("--vram", type=int, default=0, metavar="MIB")
    ap.add_argument("--label", default=None)
    ap.add_argument("--timeout", type=int, default=0, help="max seconds to wait for admission (0 = forever)")
    ap.add_argument("--shared", action="store_true", help="non-exclusive lease (VRAM reservation only)")
    ap.add_argument("cmd", nargs=argparse.REMAINDER)
    args = ap.parse_args()
    cmd = args.cmd[1:] if args.cmd[:1] == ["--"] else args.cmd
    if not cmd:
        ap.error("no command given (use: gpu-lease [opts] -- cmd ...)")
    tok = _token()
    label = args.label or os.path.basename(cmd[0])
    health_port = _start_vouch_responder()
    health_url = f"http://127.0.0.1:{health_port}/" if health_port else None
    deadline = time.time() + args.timeout if args.timeout else None
    while True:
        code, res = _call("POST", "/v1/lease", {
            "gpu": args.gpu, "initiator": f"gpu-lease:{os.environ.get('USER', 'shell')}",
            "label": label, "vram_mib": args.vram, "exclusive": not args.shared,
            "ttl_s": 900, "pid": os.getpid(), "health_url": health_url}, tok)
        if res.get("granted"):
            break
        wait = res.get("retry_in_s") or 30
        print(f"gpu-lease: deferred ({'; '.join(res.get('reasons', ['?']))}) — retrying in {wait}s",
              file=sys.stderr)
        if deadline and time.time() + wait > deadline:
            print("gpu-lease: timeout waiting for admission", file=sys.stderr)
            return 75  # EX_TEMPFAIL
        time.sleep(wait)
    lease_id, gpu_uuid = res["lease_id"], res["gpu_uuid"]
    print(f"gpu-lease: granted {res['gpu_name']} ({lease_id[:8]})", file=sys.stderr)
    stop = threading.Event()
    child_pid: list[int | None] = [None]

    def _beat() -> None:
        while not stop.wait(120):
            try:  # survive transient manager blips — a dead beat thread would let a
                  # --shared lease reap mid-job (review finding #6)
                _call("POST", f"/v1/lease/{lease_id}/heartbeat",
                      {"pid": child_pid[0]} if child_pid[0] else None, tok)
            except Exception:  # noqa: BLE001
                pass

    threading.Thread(target=_beat, daemon=True).start()
    env = dict(os.environ, CUDA_VISIBLE_DEVICES=gpu_uuid, CUDA_DEVICE_ORDER="PCI_BUS_ID")
    try:
        proc = subprocess.Popen(cmd, env=env)
        child_pid[0] = proc.pid
        # re-bind the lease to the CHILD (the actual CUDA process) so rogue-watch knows it
        try:
            _call("POST", f"/v1/lease/{lease_id}/heartbeat", {"pid": proc.pid}, tok)
        except Exception:  # noqa: BLE001
            pass
        signal.signal(signal.SIGTERM, lambda *_: proc.terminate())
        return proc.wait()
    finally:
        stop.set()
        _call("POST", f"/v1/lease/{lease_id}/release", None, tok)
        print("gpu-lease: released", file=sys.stderr)


if __name__ == "__main__":
    sys.exit(main())
